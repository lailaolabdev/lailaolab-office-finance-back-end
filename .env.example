# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Database
# DATABASE_URL="postgresql://lailaolab:lailaolab123!@localhost:5432/lailaolab_office?schema=public"
# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://postgres.sbkwuuhvcidcydlrgccw:lailaolab123!@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# JWT
JWT_SECRET=change-this-to-a-strong-secret-key
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-to-another-strong-secret
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CORS_ORIGIN=http://localhost:3000

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# S3 / MinIO (optional)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=lailaolab
S3_SECRET_KEY=lailaolab123
S3_BUCKET=lailaolab-office
S3_REGION=us-east-1

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info

# Notifications — SMTP (optional, leave blank to disable email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Lailaolab Office <no-reply@lailaolab.com>"

# Public app URL — used in email notification links
APP_URL=http://localhost:3000

# Scheduler timezone (default Asia/Vientiane)
CRON_TIMEZONE=Asia/Vientiane
